{
  "name": "@smarlhens/npm-pin-dependencies",
  "version": "0.11.0",
  "description": "NPM tool to pin down versions of installed dependencies written in TypeScript.",
  "keywords": [
    "dependencies",
    "dependency",
    "lock",
    "node",
    "npm",
    "pin",
    "typescript",
    "version",
    "versions",
    "yarn"
  ],
  "homepage": "https://github.com/smarlhens/npm-pin-dependencies#readme",
  "bugs": {
    "url": "https://github.com/smarlhens/npm-pin-dependencies/issues"
  },
  "license": "BlueOak-1.0.0",
  "author": {
    "name": "Samuel MARLHENS",
    "email": "samuel.marlhens@proton.me",
    "url": "https://github.com/smarlhens"
  },
  "repository": {
    "type": "git",
    "url": "git+https://github.com/smarlhens/npm-pin-dependencies.git"
  },
  "bin": {
    "npd": "dist/bin/npd.js",
    "npm-pin-dependencies": "dist/bin/npd.js"
  },
  "directories": {
    "lib": "lib"
  },
  "files": [
    "dist"
  ],
  "type": "module",
  "main": "./dist/lib/npd.cjs",
  "module": "./dist/lib/npd.js",
  "types": "./dist/npd.d.ts",
  "exports": {
    ".": {
      "types": "./dist/npd.d.ts",
      "require": "./dist/lib/npd.cjs",
      "import": "./dist/lib/npd.js"
    }
  },
  "scripts": {
    "build": "tsdown",
    "fmt:check": "oxfmt --check",
    "fmt:write": "oxfmt",
    "lint": "npm run fmt:check",
    "lint-staged": "lint-staged",
    "pre-commit": "npm run lint-staged",
    "prepare": "husky",
    "pretest": "npm run build",
    "test": "vitest run",
    "test:ci": "npm run test:coverage",
    "test:coverage": "npm run test -- --coverage",
    "test:watch": "vitest watch",
    "typecheck": "tsc --noEmit"
  },
  "dependencies": {
    "@pnpm/lockfile.fs": "1001.1.32",
    "@yarnpkg/lockfile": "1.1.0",
    "@yarnpkg/parsers": "3.0.3",
    "ajv": "8.18.0",
    "cli-table": "0.3.11",
    "detect-indent": "7.0.2",
    "empathic": "2.0.0",
    "listr2": "8.3.3",
    "obug": "2.1.1",
    "picocolors": "1.1.1",
    "semver": "7.7.4",
    "update-notifier": "7.3.1",
    "yargs": "17.7.2"
  },
  "devDependencies": {
    "@commitlint/cli": "20.5.0",
    "@commitlint/config-conventional": "20.5.0",
    "@types/cli-table": "0.3.4",
    "@types/node": "20.19.37",
    "@types/semver": "7.7.1",
    "@types/update-notifier": "6.0.8",
    "@types/yargs": "17.0.35",
    "@types/yarnpkg__lockfile": "1.1.9",
    "@vitest/coverage-v8": "3.1.4",
    "husky": "9.1.7",
    "knip": "6.2.0",
    "lint-staged": "15.5.2",
    "oxfmt": "0.43.0",
    "tinyexec": "1.0.4",
    "tsdown": "0.21.7",
    "typescript": "5.9.3",
    "vitest": "3.1.4"
  },
  "engines": {
    "node": "^20.19.0 || ^22.12.0 || >=24.0.0",
    "npm": ">=10.0.0"
  }
}
